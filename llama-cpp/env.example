# @dependency-start
# responsibility Defines repo-local llama.cpp environment defaults for the LocalLLM harness.
# upstream design README.md documents llama.cpp serving layout
# downstream implementation ../../../python/local_llm_agent/mcp_server.py consumes llama.cpp endpoint settings
# @dependency-end

LOCAL_LLM_PROVIDER=llama-cpp
LOCAL_LLM_PROFILE=qwen3-4b-instruct-2507-llama-cpp
LOCAL_LLM_MODEL=qwen3-4b-instruct-2507
LOCAL_LLM_HOST=0.0.0.0
LOCAL_LLM_PORT=8080
LOCAL_LLM_THREADS=28
LOCAL_LLM_CONTEXT_TOKENS=8192
LOCAL_LLM_GGUF_PATH=/models/qwen3-4b-instruct-2507-q4_k_m.gguf
LOCAL_LLM_START_SERVER=1

LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_MAX_TOKENS=1024
