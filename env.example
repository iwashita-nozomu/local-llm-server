# @dependency-start
# responsibility Documents local LLM endpoint environment variables.
# upstream design README.md describes how to source this file
# downstream implementation ../../experiments/local-llm-agent/experimentcode.py consumes these variables
# downstream environment ../../docker/codex-container-profiles.toml forwards these variables
# @dependency-end

# llama.cpp HTTP endpoint consumed inside the LocalLLM MCP container.
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1

# Local serving metadata used by docs, compose, and experiment reports.
LOCAL_LLM_PROVIDER=llama-cpp
LOCAL_LLM_PROFILE=qwen3-4b-instruct-2507-llama-cpp
LOCAL_LLM_MODEL=qwen3-4b-instruct-2507
LOCAL_LLM_HOST=0.0.0.0
LOCAL_LLM_PORT=8080
LOCAL_LLM_THREADS=28
LOCAL_LLM_THREADS_BATCH=28
LOCAL_LLM_THREADS_HTTP=4
LOCAL_LLM_OMP_THREADS=28
LOCAL_LLM_OMP_DYNAMIC=FALSE
LOCAL_LLM_OMP_WAIT_POLICY=PASSIVE
LOCAL_LLM_BLAS_THREADS=1
LOCAL_LLM_PARALLEL=1
LOCAL_LLM_BATCH_SIZE=2048
LOCAL_LLM_UBATCH_SIZE=512
LOCAL_LLM_CPU_RANGE=
LOCAL_LLM_CPU_STRICT=
LOCAL_LLM_PRIO=
LOCAL_LLM_PRIO_BATCH=
LOCAL_LLM_POLL=0
LOCAL_LLM_POLL_BATCH=0
LOCAL_LLM_NUMA=
LOCAL_LLM_CONTEXT_TOKENS=8192
LOCAL_LLM_GGUF_PATH=/models/qwen3-4b-instruct-2507-q4_k_m.gguf
LOCAL_LLM_START_SERVER=1
LOCAL_LLM_READY_TIMEOUT_SECONDS=120
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_MAX_TOKENS=1024
LOCAL_LLM_TENSOR_PARALLEL_SIZE=1

# Optional allowlisted SSH dispatch for operational commands.
LOCAL_LLM_SSH_HOST=
LOCAL_LLM_SSH_USER=
LOCAL_LLM_SSH_PORT=22
LOCAL_LLM_SSH_ALLOWED_COMMANDS=true

# Set when pulling gated Hugging Face models.
# HF_TOKEN=
